{
  "name": "@aarmos/bundle-schema",
  "version": "0.3.0-rc.2",
  "description": "Frozen schema for the Aarmos Bundle (aarmos.bundle/1) — the signed, self-contained container of AVAR receipts, policy snapshots, egress ledger rows, and guardrail events used by `aarmos incident export` and `avar verify`.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*",
    "./redaction/*": "./redaction/*"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "schemas",
    "redaction",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aarmos",
    "avar",
    "bundle",
    "audit",
    "incident-export",
    "schema"
  ],
  "license": "Apache-2.0",
  "author": "Aarmatix LLC",
  "homepage": "https://github.com/Aarmatix/aarmos-bundle-spec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aarmatix/aarmos-bundle-spec.git"
  },
  "bugs": {
    "url": "https://github.com/Aarmatix/aarmos-bundle-spec/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.2"
  }
}
