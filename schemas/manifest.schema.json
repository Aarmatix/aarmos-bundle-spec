{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aarmos.io/schemas/bundle/v1/manifest.schema.json",
  "title": "Aarmos Bundle Manifest",
  "description": "manifest.json inside an aarmos.bundle/1 container.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "bundleId",
    "workspace",
    "tenant",
    "window",
    "producer",
    "contents",
    "contentDigest"
  ],
  "properties": {
    "schema": {
      "const": "aarmos.bundle/1",
      "description": "Frozen schema identifier. Do not fork."
    },
    "bundleId": {
      "type": "string",
      "pattern": "^bnd_[0-9a-hjkmnp-tv-z]{26}$",
      "description": "ULID-style, prefixed. Stable per bundle."
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idHash", "publicKey"],
      "properties": {
        "idHash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$",
          "description": "SHA-256 of the workspace id. Raw id never leaves the workspace."
        },
        "publicKey": {
          "type": "object",
          "additionalProperties": false,
          "required": ["alg", "kid", "key"],
          "properties": {
            "alg": { "const": "Ed25519" },
            "kid": { "type": "string", "minLength": 1 },
            "key": {
              "type": "string",
              "description": "base64url-encoded Ed25519 public key (32 bytes)."
            }
          }
        }
      }
    },
    "tenant": {
      "type": "string",
      "minLength": 1,
      "description": "Tenant identifier as recorded in the policy gate."
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "aarmos-cli" },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+([-+].+)?$"
        }
      }
    },
    "narrowing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sessionIds": { "type": "array", "items": { "type": "string" } },
        "agentIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "contents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipts", "policies", "egress", "guardrails"],
      "properties": {
        "receipts": { "$ref": "#/$defs/fileGroup" },
        "policies": { "$ref": "#/$defs/fileGroup" },
        "egress": { "$ref": "#/$defs/fileGroup" },
        "guardrails": { "$ref": "#/$defs/fileGroup" },
        "invites": { "$ref": "#/$defs/fileGroup" },
        "anchor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "const": "anchor.json" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    },
    "contentDigest": {
      "$ref": "#/$defs/sha256",
      "description": "Merkle-style SHA-256 over the sorted list of {path, sha256} entries in `contents`. Excludes signatures/. Deterministic."
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowlist", "sha256"],
      "properties": {
        "allowlist": { "const": "aarmos.bundle.v1" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "fileGroup": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(receipts|policies|egress|guardrails|invites)/[A-Za-z0-9._/-]+$"
          },
          "sha256": { "$ref": "#/$defs/sha256" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
